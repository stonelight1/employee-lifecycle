# Employee Lifecycle System — environment example
# Copy to .env and replace values locally. Never commit the real .env file.

# Application
APP_ENV=development
APP_DEBUG=true
APP_HOST=127.0.0.1
APP_PORT=8013
APP_SECRET_KEY=change-me-to-a-long-random-secret

# Frontend
FRONTEND_URL=http://localhost:5178

# SQLite
DATABASE_URL=sqlite:///./data/employee_lifecycle.db

# Logging
LOG_LEVEL=INFO
LOG_DIR=./logs

# Communication text
COMMUNICATION_TEXT_MAX_LENGTH=50000

# AI feature
AI_ENABLED=false
AI_PROVIDER=openai
AI_API_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini
AI_API_KEY=
AI_TIMEOUT=30
AI_MAX_RETRIES=2
AI_DAILY_LIMIT=100
AI_MONTHLY_LIMIT=2000
